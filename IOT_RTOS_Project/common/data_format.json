{
    "_comment": "CONTRACT CHUNG — Data Format. KHONG thay doi neu chua thong nhat.",

    "mqtt_topics": {
        "sensor_data":     "iot/sensor/data",
        "device_status":   "iot/device/status",
        "device_control":  "iot/device/control"
    },

    "sensor_data_payload": {
        "_description": "ESP32 publish len iot/sensor/data moi 10 giay",
        "device_id":   { "type": "string",  "example": "esp32_1" },
        "temperature": { "type": "float",   "unit": "°C",  "example": 32.50 },
        "humidity":    { "type": "float",   "unit": "%RH", "example": 65.00 },
        "aqi":         { "type": "integer", "unit": "raw ADC (0-4095)", "example": 350 },
        "alert":       { "type": "integer", "values": "0=OK, 1=WARN, 2=CRITICAL", "example": 1 },
        "timestamp":   { "type": "int64",   "unit": "microseconds since boot (esp_timer_get_time)", "example": 123456789 }
    },

    "device_status_payload": {
        "_description": "ESP32 publish len iot/device/status khi nhan lenh GET_STATUS",
        "type":        { "type": "string",  "value": "status_report" },
        "device_id":   { "type": "string",  "example": "esp32_1" },
        "temperature": { "type": "float",   "example": 32.50 },
        "humidity":    { "type": "float",   "example": 65.00 },
        "aqi":         { "type": "integer", "example": 350 },
        "alert":       { "type": "integer", "example": 1 },
        "timestamp":   { "type": "int64",   "example": 123456789 }
    },

    "control_command_payload": {
        "_description": "Backend publish len iot/device/control de dieu khien ESP32",
        "command": {
            "type": "string",
            "valid_values": [
                "MUTE_ALARM",
                "TEST_LED",
                "REBOOT",
                "LED_RED_ON",  "LED_RED_OFF",
                "LED_YLW_ON",  "LED_YLW_OFF",
                "LED_GRN_ON",  "LED_GRN_OFF",
                "BLINK_RED",   "BLINK_YLW",  "BLINK_GRN",
                "GET_STATUS"
            ],
            "max_length": 19,
            "example": "MUTE_ALARM"
        }
    }
}