# ============================================
# Environment Configuration - Example Template
# Copy this file to .env.local for local development
# ============================================

# ============ NODE ENVIRONMENT ============
NODE_ENV=development

# ============ SERVER CONFIGURATION ============
PORT=3000
FRONTEND_PORT=8080

# ============ DATABASE CONFIGURATION ============
DB_HOST=localhost
DB_PORT=3306
DB_USER=iot_user
DB_PASSWORD=iot_password
DB_NAME=iot_db

# ============ MQTT CONFIGURATION ============
# Mặc định topic lấy từ IOT_RTOS_Project/common/data_format.json → mqtt_topics
MQTT_BROKER=mqtt://localhost:1883
# Ghi đè tùy chọn (để trống = dùng JSON): sensor_data, device_status, device_control
# MQTT_TOPIC_PUBLISH=iot/sensor/data
# MQTT_TOPIC_STATUS=iot/device/status
# MQTT_TOPIC_COMMAND=iot/device/control
MQTT_QOS=1
MQTT_RETAIN=true

# ============ LOGGING CONFIGURATION ============
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# ============ API CONFIGURATION ============
CORS_ORIGIN=http://localhost:8080
API_VERSION=1.0.0

# ============ FEATURE FLAGS ============
USE_MOCK_DATA=true
ENABLE_MQTT=true
ENABLE_DATABASE=true

# ============ SECURITY (Will be added in Day 3) ============
# JWT_SECRET=your-secret-key-here
# PASSWORD_SALT_ROUNDS=10
